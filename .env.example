# Server Configuration
PORT=9110
NODE_ENV=development

# MongoDB Configuration
LOCAL_MONGO_DB=mongodb://localhost:27017/swaraz_jwellery

# JWT Secret (change this to a secure random string)
JWTSECRET=your_super_secret_jwt_key_here_change_in_production

# Master OTP for testing (remove in production)
MASTER_OTP_LOGIN=123456

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=your_bucket_name

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Gold Price API (Optional - uses free API by default)
# Sign up at https://www.goldapi.io for more reliable service
GOLD_API_KEY=
